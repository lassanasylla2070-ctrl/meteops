apiVersion: apps/v1
kind: Deployment
metadata:
  name: meteops-frontend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: meteops-frontend
  template:
    metadata:
      labels:
        app: meteops-frontend
    spec:
      containers:
        - name: meteops-frontend
          image: {{ frontend_image }}
          ports:
            - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: meteops-frontend
spec:
  selector:
    app: meteops-frontend
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30080
  type: NodePort
