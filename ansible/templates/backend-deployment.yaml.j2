apiVersion: apps/v1
kind: Deployment
metadata:
  name: meteops-backend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: meteops-backend
  template:
    metadata:
      labels:
        app: meteops-backend
    spec:
      containers:
        - name: meteops-backend
          image: {{ backend_image }}
          ports:
            - containerPort: 3001
          env:
{% for key, value in backend_env.items() %}
            - name: {{ key }}
              value: "{{ value }}"
{% endfor %}
            - name: DATABASE_NAME
              value: "weather"
---
apiVersion: v1
kind: Service
metadata:
  name: meteops-backend
spec:
  selector:
    app: meteops-backend
  ports:
    - port: 3001
      targetPort: 3001
      nodePort: 30001
  type: NodePort
